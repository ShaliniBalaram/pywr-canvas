{
  "name": "pywr-canvas",
  "version": "1.0.0",
  "description": "Desktop application for opening, drawing, editing and validating Pywr water resource model JSON files",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:react\" \"wait-on http://localhost:3000 && electron .\"",
    "dev:react": "vite --port 3000",
    "build:react": "vite build",
    "build:electron": "electron-builder --config electron-builder.config.js",
    "build": "npm run build:react && npm run build:electron",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "reactflow": "^11.10.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3",
    "vite": "^5.4.0",
    "wait-on": "^7.2.0"
  }
}
